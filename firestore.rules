rules_version = '2';

// The Orchestral Frame — cast roster
//
// All cast data lives in a single document at /state/main so that every page
// can subscribe to the same snapshot (ledger, availability, rehearsals,
// check-ins, leaves, notices, poll, present-mode submissions).
//
// Write access is intentionally open: the production tool is a shared, trusted
// environment (the admin passcode is the gate) and the Firestore layer just
// mirrors localStorage state. If you need stricter access, put Firebase Auth
// in front and replace the `allow write` rule with a custom claim check.

service cloud.firestore {
  match /databases/{database}/documents {

    match /state/{docId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().size() < 64 &&
        request.resource.data.size() < 900 * 1024;  // < ~900 KB per doc
    }

    match /presentSubmissions/{subId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['name', 'slots', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 120 &&
        request.resource.data.slots is list &&
        request.resource.data.slots.size() < 200;
      allow update, delete: if false;
    }

    // Finals study hub — student-uploaded note metadata.
    // Open create/update/delete because the admin client at
    // finals.mathans.app/admin is the only thing that ever calls
    // them (same trusted-environment model as the rest of this
    // project).
    //
    // type is 'notes' | 'mock_paper'.
    //   At least one of {file fields, gdocsUrl, quizletUrl} must be
    //   present; multiple is fine. The card UI shows whichever
    //   buttons apply.
    //
    // Legacy 'flashcards' and 'gdocs' types from earlier versions are
    // still accepted so existing docs continue to read/update normally;
    // new uploads use 'notes' or 'mock_paper' with the relevant
    // optional URL fields instead.
    match /notes/{noteId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll([
          'title', 'uploaderName', 'type', 'subject', 'createdAt'
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() < 200 &&
        request.resource.data.uploaderName is string &&
        request.resource.data.uploaderName.size() > 0 &&
        request.resource.data.uploaderName.size() < 80 &&
        request.resource.data.type is string &&
        request.resource.data.type.size() > 0 &&
        request.resource.data.type.size() < 60 &&
        (
          // notes / mock_paper / admin-defined types: file fields OR a
          // gdocs link OR a quizlet link (or any combination).
          (!(request.resource.data.type in ['flashcards', 'gdocs']) && (
            (
              request.resource.data.keys().hasAll(['fileName', 'filePath', 'fileSize', 'downloadUrl']) &&
              request.resource.data.fileName is string &&
              request.resource.data.fileName.size() < 200 &&
              request.resource.data.filePath is string &&
              request.resource.data.filePath.size() < 300 &&
              request.resource.data.fileSize is number &&
              request.resource.data.fileSize < 50 * 1024 * 1024 &&
              request.resource.data.downloadUrl is string
            )
            ||
            (
              request.resource.data.keys().hasAll(['gdocsUrl']) &&
              request.resource.data.gdocsUrl is string &&
              request.resource.data.gdocsUrl.size() < 600
            )
            ||
            (
              request.resource.data.keys().hasAll(['quizletUrl']) &&
              request.resource.data.quizletUrl is string &&
              request.resource.data.quizletUrl.size() < 500
            )
          ))
          ||
          // Legacy 'flashcards' type — Quizlet link only.
          (request.resource.data.type == 'flashcards' &&
            request.resource.data.keys().hasAll(['quizletUrl', 'quizletSetId']) &&
            request.resource.data.quizletUrl is string &&
            request.resource.data.quizletUrl.size() < 500 &&
            request.resource.data.quizletSetId is string &&
            request.resource.data.quizletSetId.size() < 60)
          ||
          // Legacy 'gdocs' type — Google Docs link only.
          (request.resource.data.type == 'gdocs' &&
            request.resource.data.keys().hasAll(['gdocsUrl']) &&
            request.resource.data.gdocsUrl is string &&
            request.resource.data.gdocsUrl.size() < 600)
        );
      // Admin edits — allow any combination of editable fields, as long
      // as title stays valid.
      allow update: if
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() < 200;
      allow delete: if true;
    }

    // Folders — admin-managed taxonomy for notes. Single tree per project,
    // each node references its parentId (null for root nodes). Same trust
    // model as /notes: open writes with shape validation.
    match /folders/{folderId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['name', 'parentId', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80 &&
        (request.resource.data.parentId == null ||
          (request.resource.data.parentId is string &&
           request.resource.data.parentId.size() < 60));
      allow update: if
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80;
      allow delete: if true;
    }

    // Admin-managed taxonomy lists. Same trust model as /notes and /folders:
    // open writes with shape validation, gated by the admin passcode in the
    // client.
    match /subjects/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['name', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80;
      allow update: if
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 80;
      allow delete: if true;
    }

    match /noteTypes/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['value', 'label', 'createdAt']) &&
        request.resource.data.value is string &&
        request.resource.data.value.size() > 0 &&
        request.resource.data.value.size() < 60 &&
        request.resource.data.label is string &&
        request.resource.data.label.size() > 0 &&
        request.resource.data.label.size() < 80;
      allow update: if
        request.resource.data.label is string &&
        request.resource.data.label.size() > 0 &&
        request.resource.data.label.size() < 80;
      allow delete: if true;
    }

    // Admin-authored welcome popups shown on hub entry. Same trust model as
    // /notes and /folders: open writes with shape validation, gated by the
    // admin passcode in the client. Users dismiss locally via localStorage,
    // so writes happen from admin sessions only.
    match /popups/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['title', 'createdAt']) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() < 200 &&
        (!('emoji' in request.resource.data) ||
          (request.resource.data.emoji is string &&
           request.resource.data.emoji.size() < 16)) &&
        (!('description' in request.resource.data) ||
          (request.resource.data.description is string &&
           request.resource.data.description.size() < 2000)) &&
        (!('buttonText' in request.resource.data) ||
          (request.resource.data.buttonText is string &&
           request.resource.data.buttonText.size() < 120)) &&
        (!('folderId' in request.resource.data) ||
          request.resource.data.folderId == null ||
          (request.resource.data.folderId is string &&
           request.resource.data.folderId.size() < 60)) &&
        (!('active' in request.resource.data) ||
          request.resource.data.active is bool);
      allow update: if
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() < 200;
      allow delete: if true;
    }

    // Anonymous error / difficulty reports submitted from the hub. No
    // personal info is collected — message is free-form, plus a category
    // tag, the current path, and a truncated user-agent string. Admin
    // toggles resolved / deletes via /admin.
    match /reports/{id} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['message', 'createdAt']) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 1000 &&
        (!('category' in request.resource.data) ||
          (request.resource.data.category is string &&
           request.resource.data.category.size() < 40)) &&
        (!('path' in request.resource.data) ||
          (request.resource.data.path is string &&
           request.resource.data.path.size() < 300)) &&
        (!('userAgent' in request.resource.data) ||
          (request.resource.data.userAgent is string &&
           request.resource.data.userAgent.size() < 280));
      allow update: if request.resource.data.message.size() < 1000;
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
